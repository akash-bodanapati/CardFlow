# Google Sheets API
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
GOOGLE_SHEET_ID=your_sheet_id_here

# MongoDB Atlas
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/?retryWrites=true&w=majority&appName=CardFlow

# WhatsApp API
WHATSAPP_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
MANAGER_PHONE_NUMBER=your_manager_phone_number

# LLM Provider (Gemini or Claude)
GEMINI_API_KEY=your_gemini_api_key

# Optional: Claude / OpenAI API Keys
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
