# Google Sheets API Configuration
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
GOOGLE_SHEET_ID=your_google_sheet_id_here

# MongoDB Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname

# WhatsApp API Configuration
WHATSAPP_TOKEN=your_whatsapp_cloud_api_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
MANAGER_PHONE_NUMBER=your_recipient_phone_number_with_country_code_e_g_91XXXXXXXXXX

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_OCR_KEY=your_gemini_ocr_key_here
GEMINI_AUDIO_KEY=your_gemini_audio_key_here
GEMINI_ENRICHMENT_KEY=your_gemini_enrichment_key_here

# Optional CORS Origins (comma-separated, default is http://localhost:5173)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80

# Deployed Backend Public Base URL (Required for public audio notes in Google Sheets, localhost is blocked)
PUBLIC_BASE_URL=https://your-backend-domain.com